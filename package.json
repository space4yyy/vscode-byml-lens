{
  "name": "vscode-byml-inspector",
  "displayName": "BYML Lens",
  "description": "High-performance editor for .byml, .bgyml, .pack and .zs files. Features native YAML views and SARC mounting.",
  "version": "0.1.8",
  "publisher": "space4",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/space4yyy/vscode-byml-lens"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "byml",
    "sarc",
    "pack",
    "zstd",
    "splatoon",
    "zelda"
  ],
  "activationEvents": [
    "onFileSystem:sarc",
    "onFileSystem:byml-edit",
    "onCustomEditor:byml-inspector.redirector",
    "onCustomEditor:byml-inspector.sarc-redirector"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "byml-lens": "./dist/cli.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "byml-inspector.unmountPack",
        "title": "Unmount .pack Archive",
        "category": "BYML"
      },
      {
        "command": "byml-inspector.compareWithOriginal",
        "title": "Compare with Original Binary",
        "category": "BYML",
        "icon": "$(diff)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "byml-inspector.unmountPack",
          "when": "resourceScheme == sarc",
          "group": "navigation"
        },
        {
          "command": "byml-inspector.compareWithOriginal",
          "when": "resourceFilename =~ /\\.(byml|bgyml|byaml)(\\.zs)?$/",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "BYML Lens",
      "properties": {
        "byml-lens.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable detailed debug logging in the Output panel. Helpful for troubleshooting corrupted files."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "byml-inspector.redirector",
        "displayName": "BYML YAML Viewer",
        "selector": [
          {
            "filenamePattern": "*.{byml,bgyml,byaml,byml.zs,bgyml.zs,byaml.zs}"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "byml-inspector.sarc-redirector",
        "displayName": "SARC Auto-Mounter",
        "selector": [
          {
            "filenamePattern": "*.{pack,sarc,pack.zs,sarc.zs}"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle": "npm run bundle:extension && npm run bundle:cli",
    "bundle:extension": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "bundle:cli": "esbuild ./src/cli.ts --bundle --outfile=dist/cli.js --external:vscode --format=cjs --platform=node --banner:js=\"#!/usr/bin/env node\"",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@pretendonetwork/nintendo-files": "^1.1.0",
    "@themezernx/sarclib": "^1.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.25.0",
    "eslint": "^8.54.0",
    "fzstd": "^0.1.0",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.3.2",
    "zstdify": "^1.4.0"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
